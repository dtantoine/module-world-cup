<?xml version="1.0"?>
<!--
/**
 * Antoine World Cup Hub — module declaration.
 *
 * Standalone public live-stats module. Stateless: the live tournament snapshot
 * is held in the `worldcup_snapshot` cache type, so there is no db_schema.xml.
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Module/etc/module.xsd">
    <module name="Antoine_WorldCup">
        <sequence>
            <module name="Magento_Store"/>
            <module name="Magento_Backend"/>
            <module name="Magento_Config"/>
            <module name="Magento_Cron"/>
        </sequence>
    </module>
</config>

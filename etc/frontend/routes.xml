<?xml version="1.0"?>
<!--
/**
 * Antoine World Cup Hub — frontend route. frontName `world-cup` →
 * /world-cup (page) and /world-cup/data (JSON snapshot).
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:App/etc/routes.xsd">
    <router id="standard">
        <route id="worldcup" frontName="world-cup">
            <module name="Antoine_WorldCup"/>
        </route>
    </router>
</config>

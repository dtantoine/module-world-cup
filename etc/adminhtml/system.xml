<?xml version="1.0"?>
<!--
/**
 * Antoine World Cup Hub — store configuration (Stores → Antoine → World Cup Hub):
 * enable toggle, upstream base URL, encrypted JWT token, poll interval, cache TTL.
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="antoine" translate="label" sortOrder="400">
            <label>Antoine</label>
        </tab>
        <section id="antoine_worldcup" translate="label" type="text" sortOrder="20"
                 showInDefault="1" showInWebsite="0" showInStore="0">
            <label>World Cup Hub</label>
            <tab>antoine</tab>
            <resource>Antoine_WorldCup::config</resource>
            <group id="general" translate="label" type="text" sortOrder="10"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>General</label>
                <field id="enabled" translate="label" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="base_url" translate="label comment" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Upstream Base URL</label>
                    <comment>Default https://worldcup26.ir</comment>
                </field>
                <field id="jwt_token" translate="label comment" type="obscure" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Upstream JWT Token</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment>One-time token from POST /auth/authenticate (valid ~84 days). Stored encrypted; never sent to the browser.</comment>
                </field>
                <field id="poll_interval" translate="label comment" type="text" sortOrder="40"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Frontend Live-Poll Interval (seconds)</label>
                    <comment>How often the page re-fetches /world-cup/data while matches are live (default 45). The cron-side refresh runs every minute independently.</comment>
                </field>
                <field id="cache_ttl" translate="label comment" type="text" sortOrder="50"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Snapshot Cache TTL (seconds)</label>
                </field>
            </group>
        </section>
    </system>
</config>
